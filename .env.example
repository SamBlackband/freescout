# FreeScout service env vars for the dedicated support deployment.
# Recommended deployment target:
# - Railway project: same project as the existing Handled backend
# - FreeScout service name: freescout-support
# - FreeScout DB service name: handled-support-db
# - Root directory: freescout
# - Public hostname: support.handled.group

ADMIN_EMAIL=founder@handled.group
ADMIN_FIRST_NAME=Handled
ADMIN_LAST_NAME=Support
ADMIN_PASS=change-me
APP_KEY=

SITE_URL=https://support.handled.group
APPLICATION_NAME=Handled Support
SETUP_TYPE=AUTO
ENABLE_AUTO_UPDATE=TRUE

DB_TYPE=pgsql
DB_HOST=
DB_PORT=5432
DB_NAME=freescout
DB_USER=freescout
DB_PASS=
DB_PGSQL_SSL_MODE=require

# Railway mapping from the handled-support-db Postgres service:
# DB_HOST = PGHOST
# DB_PORT = PGPORT
# DB_NAME = PGDATABASE
# DB_USER = PGUSER
# DB_PASS = PGPASSWORD
#
# APP_KEY should be a stable Laravel app key and must not change between deploys.
# The local wrapper syncs this value into FreeScout's generated .env on every boot,
# because the upstream image does not consume APP_KEY directly from Railway vars.
# Example generation command:
# python -c "import base64, secrets; print('base64:' + base64.b64encode(secrets.token_bytes(32)).decode())"

# Optional proxy settings if Railway or another edge proxy sits in front.
APP_TRUSTED_PROXIES=*

# Handled support sync bridge
HANDLED_SUPPORT_SYNC_ENABLED=false
HANDLED_SUPPORT_SYNC_URL=
HANDLED_SUPPORT_SYNC_SECRET=

# Persistent storage is still strongly recommended in hosting:
# - /data
# - optionally /assets/modules if installing custom or purchased modules

# Brand mailbox model (managed in FreeScout UI, not consumed directly by the container):
# - support@glassi.co
# - support@rinse.io
# - support@detaild.io
# - support@crumb.io
# - support@fitreply.io
