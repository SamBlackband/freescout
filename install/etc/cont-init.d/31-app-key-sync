#!/command/with-contenv bash

source /assets/functions/00-container
prepare_service
PROCESS_NAME="freescout-app-key-sync"

check_service_initialized init 30-freescout

CONFIG_FILES=()
for candidate in "/data/config/.env" "/data/config" "${NGINX_WEBROOT}/.env"; do
    if [ -f "${candidate}" ]; then
        CONFIG_FILES+=("${candidate}")
    fi
done

upsert_env_value() {
    local file="$1"
    local key="$2"
    local value="$3"
    local tmp_file

    tmp_file="$(mktemp)"
    if [ -f "${file}" ]; then
        grep -v "^${key}=" "${file}" > "${tmp_file}" || true
    fi
    printf "%s=%s\n" "${key}" "${value}" >> "${tmp_file}"
    cat "${tmp_file}" | sudo -u "${NGINX_USER}" tee "${file}" > /dev/null
    rm -f "${tmp_file}"
    chown "${NGINX_USER}":"${NGINX_GROUP}" "${file}"
}

sync_env_key() {
    local key="$1"
    local value="${!key:-}"

    if [ -z "${value}" ]; then
        return
    fi

    for config_file in "${CONFIG_FILES[@]}"; do
        upsert_env_value "${config_file}" "${key}" "${value}"
    done
}

if [ "${#CONFIG_FILES[@]}" -gt 0 ]; then
    print_info "Syncing persisted FreeScout env into ${CONFIG_FILES[*]}"
    for env_key in \
        APP_KEY \
        APP_ENV \
        APP_DEBUG \
        APP_URL \
        ENABLE_AUTO_UPDATE \
        MAIL_DRIVER \
        MAIL_HOST \
        MAIL_PORT \
        MAIL_FROM_ADDRESS \
        MAIL_FROM_NAME \
        MAIL_ENCRYPTION \
        MAIL_USERNAME \
        MAIL_PASSWORD \
        MAIL_AUTH_MODE \
        MAIL_SMTP_TIMEOUT \
        HANDLED_SUPPORT_SYNC_ENABLED \
        HANDLED_SUPPORT_SYNC_URL \
        HANDLED_SUPPORT_SYNC_SECRET
    do
        sync_env_key "${env_key}"
    done
else
    print_warn "FreeScout env file not found in /data/config/.env, /data/config, or ${NGINX_WEBROOT}/.env - skipping APP_KEY sync"
fi

chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT}/bootstrap/cache" "${NGINX_WEBROOT}/storage"
chmod -R ug+rwX "${NGINX_WEBROOT}/bootstrap/cache" "${NGINX_WEBROOT}/storage"

rm -rf "${NGINX_WEBROOT}/public/css/builds" "${NGINX_WEBROOT}/public/js/builds"
mkdir -p "${NGINX_WEBROOT}/public/css/builds" "${NGINX_WEBROOT}/public/js/builds"
chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT}/public/css/builds" "${NGINX_WEBROOT}/public/js/builds"
chmod -R ug+rwX "${NGINX_WEBROOT}/public/css/builds" "${NGINX_WEBROOT}/public/js/builds"

cd "${NGINX_WEBROOT}" || exit 1
if [ -f "${NGINX_WEBROOT}/artisan" ]; then
    silent sudo -u "${NGINX_USER}" php artisan config:clear
    silent sudo -u "${NGINX_USER}" php artisan view:clear
    silent sudo -u "${NGINX_USER}" php artisan route:clear
    silent sudo -u "${NGINX_USER}" php artisan freescout:clear-cache
fi

liftoff
